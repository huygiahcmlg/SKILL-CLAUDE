      1  #!/bin/bash
      2  # Fetch Google Autocomplete for seed keyword + 7 strategic varia
         nts
      3 +# Uses Python urllib to handle Vietnamese UTF-8 encoding correct
        +ly on Windows                                                   
      4  # Usage: fetch-autocomplete-variants.sh <seed> <gl> <hl> <output
         _file>
      5  # Costs: 8 SerpAPI credits per run
      6  
     ...
      19    exit 1
      20  fi
      21  
      21 -# 8 strategic query variants (8 credits total)                 
      22 -QUERIES=(                                                      
      23 -  "$SEED"                                                      
      24 -  "cách $SEED"                                                 
      25 -  "$SEED là gì"                                                
      26 -  "mua $SEED"                                                  
      27 -  "$SEED nào tốt"                                              
      28 -  "$SEED giá rẻ"                                               
      29 -  "$SEED tốt nhất"                                             
      30 -  "$SEED ở đâu"                                                
      31 -)                                                              
      22 +PYTHONIOENCODING=utf-8 python3 - << PYEOF                      
      23 +import urllib.request, urllib.parse, json, time, sys           
      24  
      33 -> "$OUTPUT_FILE"                                               
      25 +API_KEY = "${SERPAPI_KEY}"                                     
      26 +GL = "${GL}"                                                   
      27 +HL = "${HL}"                                                   
      28 +SEED = "${SEED}"                                               
      29 +OUTPUT_FILE = r"${OUTPUT_FILE}"                                
      30  
      35 -for QUERY in "${QUERIES[@]}"; do                               
      36 -  RESULT=$(curl -s "https://serpapi.com/search.json" \         
      37 -    --get \                                                    
      38 -    --data-urlencode "engine=google_autocomplete" \            
      39 -    --data-urlencode "q=${QUERY}" \                            
      40 -    --data-urlencode "gl=${GL}" \                              
      41 -    --data-urlencode "hl=${HL}" \                              
      42 -    --data-urlencode "api_key=${SERPAPI_KEY}")                 
      31 +# 8 strategic query variants                                   
      32 +QUERIES = [                                                    
      33 +    SEED,                                                      
      34 +    "cách " + SEED,                                            
      35 +    SEED + " là gì",                                           
      36 +    "mua " + SEED,                                             
      37 +    SEED + " nào tốt",                                         
      38 +    SEED + " giá rẻ",                                          
      39 +    SEED + " tốt nhất",                                        
      40 +    SEED + " ở đâu",                                           
      41 +]                                                              
      42  
      44 -  # Tag each response with source query                        
      45 -  echo "{\"source_query\": \"${QUERY}\", \"response\": ${RESULT
         -}}" >> "$OUTPUT_FILE"                                          
      46 -  sleep 0.3                                                    
      47 -done                                                           
      43 +with open(OUTPUT_FILE, "w", encoding="utf-8") as out:          
      44 +    for query in QUERIES:                                      
      45 +        params = urllib.parse.urlencode({                      
      46 +            "engine": "google_autocomplete",                   
      47 +            "q": query,                                        
      48 +            "gl": GL,                                          
      49 +            "hl": HL,                                          
      50 +            "api_key": API_KEY                                 
      51 +        })                                                     
      52 +        url = "https://serpapi.com/search.json?" + params      
      53 +        try:                                                   
      54 +            with urllib.request.urlopen(url, timeout=10) as res
         +p:                                                             
      55 +                data = json.loads(resp.read().decode("utf-8")) 
      56 +            obj = {"source_query": query, "response": data}    
      57 +        except Exception as e:                                 
      58 +            obj = {"source_query": query, "response": {"error":
         + str(e), "suggestions": []}}                                   
      59  
      49 -echo "$OUTPUT_FILE"                                            
      60 +        out.write(json.dumps(obj, ensure_ascii=False) + "\n")  
